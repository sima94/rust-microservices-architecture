# Database credentials (used by Patroni post-init scripts and PgBouncer)
DB_USER=rust_user
DB_PASSWORD=rust_pass

# Database names
USER_DB_NAME=rust_db
AUTH_DB_NAME=auth_db

# JWT secret (CHANGE THIS in production!)
JWT_SECRET=your-dev-secret-change-in-production

# Kafka
KAFKA_BROKER=kafka:29092

# Redis
REDIS_URL=redis://redis:6379

# PgBouncer pool settings
PGBOUNCER_MAX_CLIENT_CONN=200
PGBOUNCER_DEFAULT_POOL_SIZE=20
PGBOUNCER_MIN_POOL_SIZE=5

# DB pool size for services
DB_POOL_MAX_SIZE=10
