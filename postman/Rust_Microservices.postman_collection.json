    },
    {
      "description": "Run these requests in order to complete the full OAuth2/PKCE authentication flow. Each step auto-saves variables for the next.",
      "item": [
        {
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var json = pm.response.json();",
                  "    pm.collectionVariables.set('auth_user_id', json.id);",
                  "    pm.test('1.1 Register User - success', function () {",
                  "        pm.response.to.have.status(201);",
                  "    });",
                  "} else if (pm.response.code === 409) {",
                  "    pm.test('1.1 Register User - already exists (OK)', function () {",
                  "        pm.response.to.have.status(409);",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "name": "1.1 Register User",
          "request": {
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{test_email}}\",\n  \"password\": \"{{test_password}}\"\n}"
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "method": "POST",
            "url": "{{auth_url}}/api/v1/auth/register"
          }
        },
        {
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('1.2 Register OAuth Client - success', function () {",
                  "    pm.response.to.have.status(200);",
                  "    var json = pm.response.json();",
                  "    pm.collectionVariables.set('client_secret', json.client_secret);",
                  "    pm.collectionVariables.set('client_id', json.client_id);",
                  "});"
                ]
              }
            }
          ],
          "name": "1.2 Register OAuth Client",
          "request": {
            "body": {
              "mode": "raw",
              "raw": "{\n  \"client_name\": \"PostmanApp\",\n  \"redirect_uri\": \"http://localhost:3000/callback\",\n  \"scopes\": \"read write\"\n}"
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "method": "POST",
            "url": "{{auth_url}}/api/v1/clients/register"
          }
        },
        {
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Generate PKCE code_verifier and code_challenge",
                  "function base64URLEncode(buffer) {",
                  "    return buffer.toString('base64')",
                  "        .replace(/\\+/g, '-')",
                  "        .replace(/\\//g, '_')",
                  "        .replace(/=+$/, '');",
                  "}",
                  "",
                  "var verifier = base64URLEncode(require('crypto').randomBytes(32));",
                  "pm.collectionVariables.set('code_verifier', verifier);",
                  "",
                  "var challenge = base64URLEncode(",
                  "    require('crypto').createHash('sha256').update(verifier).digest()",
                  ");",
                  "pm.collectionVariables.set('code_challenge', challenge);",
                  "",
                  "var state = base64URLEncode(require('crypto').randomBytes(16));",
                  "pm.collectionVariables.set('state', state);",
                  "",
                  "console.log('code_verifier:', verifier);",
                  "console.log('code_challenge:', challenge);",
                  "console.log('state:', state);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('1.3 Authorize (PKCE) - success', function () {",
                  "    pm.response.to.have.status(200);",
                  "    var json = pm.response.json();",
                  "    pm.collectionVariables.set('auth_code', json.code);",
                  "});"
                ]
              }
            }
          ],
          "name": "1.3 Authorize (PKCE)",
          "request": {
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{test_email}}\",\n  \"password\": \"{{test_password}}\"\n}"
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "method": "POST",
            "url": {
              "host": [
                "{{auth_url}}"
              ],
              "path": [
                "api",
                "v1",
                "oauth",
                "authorize"
              ],
              "query": [
                {
                  "key": "state",
                  "value": "{{state}}"
                },
                {
                  "key": "response_type",
                  "value": "code"
                },
                {
                  "key": "client_id",
                  "value": "{{client_id}}"
                },
                {
                  "key": "scope",
                  "value": "read write"
                },
                {
                  "key": "code_challenge",
                  "value": "{{code_challenge}}"
                },
                {
                  "key": "code_challenge_method",
                  "value": "S256"
                },
                {
                  "key": "redirect_uri",
                  "value": "http://localhost:3000/callback"
                }
              ],
              "raw": "{{auth_url}}/api/v1/oauth/authorize?state={{state}}&response_type=code&client_id={{client_id}}&scope=read write&code_challenge={{code_challenge}}&code_challenge_method=S256&redirect_uri=http://localhost:3000/callback"
            }
          }
        },
        {
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('1.4 Exchange Code for Token - success', function () {",
                  "    pm.response.to.have.status(200);",
                  "    var json = pm.response.json();",
                  "    if (json.refresh_token) {",
                  "        pm.collectionVariables.set('refresh_token', json.refresh_token);",
                  "    }",
                  "    pm.collectionVariables.set('access_token', json.access_token);",
                  "});"
                ]
              }
            }
          ],
          "name": "1.4 Exchange Code for Token",
          "request": {
            "body": {
              "mode": "raw",
              "raw": "{\n  \"client_id\": \"{{client_id}}\",\n  \"client_secret\": \"{{client_secret}}\",\n  \"code\": \"{{auth_code}}\",\n  \"code_verifier\": \"{{code_verifier}}\",\n  \"grant_type\": \"authorization_code\",\n  \"redirect_uri\": \"http://localhost:3000/callback\"\n}"
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "method": "POST",
            "url": "{{auth_url}}/api/v1/oauth/token"
          }
        },
        {
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('1.5 Refresh Token - success', function () {",
                  "    pm.response.to.have.status(200);",
                  "    var json = pm.response.json();",
                  "    if (json.refresh_token) {",
                  "        pm.collectionVariables.set('refresh_token', json.refresh_token);",
                  "    }",
                  "    pm.collectionVariables.set('access_token', json.access_token);",
                  "});"
                ]
              }
            }
          ],
          "name": "1.5 Refresh Token",
          "request": {
            "body": {
              "mode": "raw",
              "raw": "{\n  \"client_id\": \"{{client_id}}\",\n  \"client_secret\": \"{{client_secret}}\",\n  \"grant_type\": \"refresh_token\",\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "method": "POST",
            "url": "{{auth_url}}/api/v1/oauth/token"
          }
        },
        {
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('1.6 Client Credentials Grant - success', function () {",
                  "    pm.response.to.have.status(200);",
                  "    var json = pm.response.json();",
                  "    pm.collectionVariables.set('access_token', json.access_token);",
                  "});"
                ]
              }
            }
          ],
          "name": "1.6 Client Credentials Grant",
          "request": {
            "body": {
              "mode": "raw",
              "raw": "{\n  \"client_id\": \"{{client_id}}\",\n  \"client_secret\": \"{{client_secret}}\",\n  \"grant_type\": \"client_credentials\",\n  \"scope\": \"read write\"\n}"
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "method": "POST",
            "url": "{{auth_url}}/api/v1/oauth/token"
          }
        },
        {
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('1.7 Revoke Token', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ],
          "name": "1.7 Revoke Token",
          "request": {
            "body": {
              "mode": "raw",
              "raw": "{\n  \"client_id\": \"{{client_id}}\",\n  \"client_secret\": \"{{client_secret}}\",\n  \"token\": \"{{refresh_token}}\"\n}"
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "method": "POST",
            "url": "{{auth_url}}/api/v1/oauth/revoke"
          }
        }
      ],
      "name": "1. Auth Flow (run in order)"
    },
    {
      "auth": {
        "bearer": [
          {
            "key": "token",
            "value": "{{access_token}}"
          }
        ],
        "type": "bearer"
      },
      "description": "All requests use {{access_token}} from the Auth Flow. Run folder '1. Auth Flow' first.",
      "item": [
