            }
          ],
          "name": "Get Deleted User (expect 404)",
          "request": {
            "method": "GET",
            "url": "{{gateway_url}}/api/v1/users/{{user_id}}"
          }
        },
        {
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Get Nonexistent User (expect 404)', function () {",
                  "    pm.response.to.have.status(404);",
                  "});"
                ]
              }
            }
          ],
          "name": "Get Nonexistent User (expect 404)",
          "request": {
            "method": "GET",
            "url": "{{gateway_url}}/api/v1/users/999999"
          }
        }
      ],
      "name": "2. User CRUD (requires token)"
