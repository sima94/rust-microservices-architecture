{
  "info": {
    "description": "Full API collection for auth-service and user-service with chained OAuth2/PKCE flow.\n\nRun requests in order within '1. Auth Flow' to set up authentication, then use '2. User CRUD'.",
    "name": "Rust Microservices Architecture",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
