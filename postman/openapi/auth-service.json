{
  "components": {
    "schemas": {
      "AuthorizeParams": {
        "properties": {
          "client_id": {
            "type": "string"
          },
          "code_challenge": {
            "type": "string"
          },
          "code_challenge_method": {
            "type": "string"
          },
          "redirect_uri": {
            "type": "string"
          },
          "response_type": {
            "type": "string"
          },
          "scope": {
            "type": "string"
          },
          "state": {
            "type": "string"
          }
        },
        "required": [
          "response_type",
          "client_id",
          "redirect_uri",
          "scope",
          "state",
          "code_challenge",
          "code_challenge_method"
        ],
        "type": "object"
      },
      "AuthorizeResponse": {
        "properties": {
          "code": {
            "type": "string"
          },
          "state": {
            "type": "string"
          }
        },
        "required": [
          "code",
          "state"
        ],
        "type": "object"
      },
      "ClientRegisterRequest": {
        "properties": {
          "client_name": {
            "type": "string"
          },
          "redirect_uri": {
            "type": "string"
          },
          "scopes": {
            "type": "string"
          }
        },
        "required": [
          "client_name",
          "redirect_uri",
          "scopes"
        ],
        "type": "object"
      },
      "ClientRegisterResponse": {
        "properties": {
          "client_id": {
            "type": "string"
          },
          "client_name": {
            "type": "string"
          },
          "client_secret": {
            "type": "string"
          },
          "redirect_uri": {
            "type": "string"
          },
          "scopes": {
            "type": "string"
          }
        },
        "required": [
          "client_id",
          "client_secret",
          "client_name",
          "redirect_uri",
          "scopes"
        ],
        "type": "object"
      },
      "LoginRequest": {
        "properties": {
          "email": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        },
        "required": [
          "email",
          "password"
        ],
        "type": "object"
      },
      "RegisterRequest": {
        "properties": {
          "email": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        },
        "required": [
          "email",
          "password"
        ],
        "type": "object"
      },
      "RegisterResponse": {
        "properties": {
          "email": {
            "type": "string"
          },
          "id": {
            "format": "int32",
            "type": "integer"
          }
        },
        "required": [
          "id",
          "email"
        ],
        "type": "object"
      },
      "RevokeRequest": {
        "properties": {
          "client_id": {
            "type": "string"
          },
          "client_secret": {
            "type": "string"
          },
          "token": {
            "type": "string"
          }
        },
        "required": [
          "token",
          "client_id",
          "client_secret"
        ],
        "type": "object"
      },
      "TokenRequest": {
        "properties": {
          "client_id": {
            "type": "string"
          },
          "client_secret": {
            "type": "string"
          },
          "code": {
            "type": [
              "string",
              "null"
            ]
          },
          "code_verifier": {
            "type": [
              "string",
              "null"
            ]
          },
          "grant_type": {
            "type": "string"
          },
          "redirect_uri": {
            "type": [
              "string",
              "null"
            ]
          },
          "refresh_token": {
            "type": [
              "string",
              "null"
            ]
          },
          "scope": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "required": [
          "grant_type",
          "client_id",
          "client_secret"
        ],
        "type": "object"
      },
      "TokenResponse": {
        "properties": {
          "access_token": {
            "type": "string"
          },
          "expires_in": {
            "format": "int64",
            "type": "integer"
          },
          "refresh_token": {
            "type": [
              "string",
              "null"
            ]
          },
          "scope": {
            "type": "string"
          },
          "token_type": {
            "type": "string"
          }
        },
        "required": [
          "access_token",
          "token_type",
          "expires_in",
          "scope"
        ],
        "type": "object"
      }
    }
  },
  "info": {
    "description": "Authentication and OAuth2 microservice",
    "license": {
      "name": ""
    },
    "title": "Auth Service API",
    "version": "1.0.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/v1/auth/register": {
      "post": {
        "operationId": "register",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RegisterResponse"
                }
              }
            },
            "description": "User registered"
          },
          "400": {
            "description": "Invalid request"
          },
          "409": {
            "description": "Email already exists"
          }
        },
        "tags": [
          "Auth"
        ]
      }
    },
    "/api/v1/clients/register": {
      "post": {
        "operationId": "register_client",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ClientRegisterRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ClientRegisterResponse"
                }
              }
            },
            "description": "OAuth client registered"
          }
        },
        "tags": [
          "Clients"
        ]
      }
    },
    "/api/v1/oauth/authorize": {
      "post": {
        "operationId": "authorize",
        "parameters": [
          {
            "in": "query",
            "name": "response_type",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "client_id",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "redirect_uri",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "scope",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "state",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "code_challenge",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "code_challenge_method",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthorizeResponse"
                }
              }
            },
            "description": "Authorization code issued"
          },
          "400": {
            "description": "Invalid client or request"
          },
          "401": {
            "description": "Invalid credentials"
          }
        },
        "tags": [
          "OAuth"
        ]
      }
    },
    "/api/v1/oauth/revoke": {
      "post": {
        "operationId": "revoke",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RevokeRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Token revoked"
          }
        },
        "tags": [
          "OAuth"
        ]
      }
    },
    "/api/v1/oauth/token": {
      "post": {
        "operationId": "token",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TokenRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            },
            "description": "Token issued"
          },
          "400": {
            "description": "Invalid grant"
          },
          "401": {
            "description": "Invalid client"
          }
        },
        "tags": [
          "OAuth"
        ]
      }
    },
    "/health": {
      "get": {
        "operationId": "health_check",
        "responses": {
          "200": {
            "description": "Service healthy"
          },
          "503": {
            "description": "Service degraded"
          }
        },
        "tags": [
          "Health"
        ]
      }
    }
  },
  "tags": [
    {
      "description": "User registration",
      "name": "Auth"
    },
    {
      "description": "OAuth client management",
      "name": "Clients"
    },
    {
      "description": "OAuth2 authorization flow (PKCE)",
      "name": "OAuth"
    },
    {
      "description": "Health check",
      "name": "Health"
    }
  ]
}