# Copy to .secrets/staging.env and fill real values.

DB_USER=rust_user
DB_PASSWORD=change-me
JWT_SECRET=change-me

AUTH_DATABASE_URL=postgres://rust_user:change-me@auth-db-pgbouncer-write:5432/auth_db?sslmode=disable
AUTH_DATABASE_READ_URL=postgres://rust_user:change-me@auth-db-pgbouncer-read:5432/auth_db?sslmode=disable
USER_DATABASE_URL=postgres://rust_user:change-me@user-db-pgbouncer-write:5432/rust_db?sslmode=disable
USER_DATABASE_READ_URL=postgres://rust_user:change-me@user-db-pgbouncer-read:5432/rust_db?sslmode=disable
JWT_SHARED_SECRET=change-me

